# Copy to .env.local for local dev:  cp .env.example .env.local
#
# Railway (Root Directory = web, volume mounted at /app/data):
#   DATABASE_URL=file:/app/data/league.db
#   SESSION_PASSWORD=<random 32+ char secret>
#   SITE_ADMIN_USERNAME=zomsoth
#
# Local dev:
#   DATABASE_URL=file:./data/league.db

# SQLite file path
DATABASE_URL=file:./data/league.db

# iron-session cookie encryption — required in production (32+ chars)
SESSION_PASSWORD=change-me-to-a-random-32-char-or-longer-secret

# Optional: dev bootstrap credentials (scripts only, not used by Next.js)
# DEV_ADMIN_USERNAME=zomsoth
# DEV_ADMIN_PASSWORD=baseball123

# Optional: AI beat reporter (Inky the Blooper)
# ANTHROPIC_API_KEY=
# AI_NEWS_MODEL=claude-opus-4-8
# INKY_AUTO_DRAFT_GAME=true   — auto-draft game recap on stats upload (commissioner still publishes)

# Optional: Discord webhook for league events and published Morning Star stories
# DISCORD_WEBHOOK_URL=

# Optional: Google OAuth (sign-in + link email for password recovery)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APP_URL=http://localhost:3000

# Optional: password reset emails via Resend (logs to console in dev without this)
# RESEND_API_KEY=
# EMAIL_FROM=Mario Baseball Hub <noreply@yourdomain.com>
