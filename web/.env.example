# Copy to .env.local for local dev:  cp .env.example .env.local
#
# Railway (Root Directory = web, volume mounted at /app/data):
#   DATABASE_URL=file:/app/data/league.db
#   SESSION_PASSWORD=<random 32+ char secret>
#   SITE_ADMIN_USERNAME=zomsoth
#
# Local dev:
#   DATABASE_URL=file:./data/league.db

# SQLite file path
DATABASE_URL=file:./data/league.db

# iron-session cookie encryption — required in production (32+ chars)
SESSION_PASSWORD=change-me-to-a-random-32-char-or-longer-secret

# Optional: dev bootstrap credentials (scripts only, not used by Next.js)
# DEV_ADMIN_USERNAME=zomsoth
# DEV_ADMIN_PASSWORD=baseball123

# Production (Railway):
#   SITE_ADMIN_USERNAME=zomsoth          — auto-admin that username on register/login
#   ADMIN_SETUP_SECRET=<random secret>   — claim admin at /setup-admin while logged in
